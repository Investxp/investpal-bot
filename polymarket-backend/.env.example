# InvestPal Polymarket Trade Engine — .env Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# ── Required for ALL modes ──────────────────────────────────────
# Your Polygon wallet private key (for CLOB auth + on-chain actions)
# Get from MetaMask → Account Details → Export Private Key
# WARNING: Treat this like a password. Never share it.
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Required for POLY_1271 (deposit wallet) orders ─────────────
# Deposit wallet address — created via Polymarket UI → Wallet → Create Deposit Wallet
# This is the smart-contract wallet that holds pUSD for trading
POLYMARKET_FUNDER_ADDRESS=0xYOUR_DEPOSIT_WALLET_ADDRESS

# Builder API credentials (from polymarket.com → Settings → Developer → API Keys)
# Required for WALLET batch relayer submissions (approvals)
POLYMARKET_BUILDER_KEY=your_builder_api_key
POLYMARKET_BUILDER_SECRET=your_builder_api_secret
POLYMARKET_BUILDER_PASSPHRASE=your_builder_api_passphrase

# ── Network ────────────────────────────────────────────────────
# 137 = Polygon Mainnet (LIVE trading)
# 80001 = Mumbai Testnet (TESTING only — no real funds)
CHAIN_ID=137

# ── Connectivity (optional) ────────────────────────────────────
# HTTP/SOCKS5 proxy for API calls (bypass geo-restrictions in restricted regions)
# Example: socks5h://127.0.0.1:9050 (Tor), http://proxy.example.com:8080
POLYMARKET_PROXY=

# Use Tor (auto-detect on 127.0.0.1:9050). Set "true" to force Tor routing.
POLYMARKET_USE_TOR=

# Override CLOB API endpoint. Leave empty for default (automatic per chain).
POLYMARKET_RELAY=

# ── Server ─────────────────────────────────────────────────────
PORT=8090

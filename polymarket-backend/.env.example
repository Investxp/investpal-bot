# InvestPal Polymarket Engine — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.

# Your Polygon wallet private key (for CLOB live trading)
# Get from MetaMask → Account Details → Export Private Key
# WARNING: Anyone with this key controls your funds.
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your Polygon wallet public address (for fetching positions/orders)
POLYMARKET_FUNDER_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Chain ID: 137 = Polygon Mainnet (default), 80001 = Mumbai Testnet
CHAIN_ID=137

# Server port (default 8090)
PORT=8090
